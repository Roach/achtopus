#!/usr/bin/env python3
"""
Achtopus — deterministic driver (prototype).

Takes the conductor OUT of the LLM hot loop. Coordination — fan-out, budget,
verify gating, manifest state, synthesis handoff — is plain Python here; an LLM is
spawned ONLY at the leaves (the persona agents that do real work). There is no
growing narration context being re-billed every turn, which is the ~22%-of-run
conductor cost that docs/harness.md diagnoses.

Usage:
    bin/run <plan.json> [--dry-run] [--concurrency N]
    bin/run --goal "<what to do>" [--budget 5.00] [--dry-run]   # conductor authors the plan

In --goal mode the ONLY LLM coordination call is the conductor authoring wire/plan.json;
everything after (fan-out, budget, gating, synthesis) is deterministic code.

Plan schema (see docs/harness.md and the example under examples/):
    {
      "budget_usd": 5.00,               # hard ceiling; the governor refuses to spawn past it
      "est_agent_usd": 0.15,            # STARTING per-agent projection, used only until enough
                                         #   real calls have landed — see reserved_estimate()
      "default_model": "claude-sonnet-5",
      "target_repo": "/path/to/repo",   # optional; enables worktree isolation
      "tasks": [
        {"id": "t1", "persona": "soloist", "prompt": "...",
         "verify": "pair",              # none | single | pair | quorum3 | quorum5 (default: single)
         "model": "claude-sonnet-5",    # optional per-task override
         "isolate": true,               # optional; git-worktree the target_repo
         "scope": ["services/checkout"],# optional blast-radius allowlist (path prefixes/globs,
                                         #   relative to target_repo); only checked if "target" is set
         "target": "services/checkout/deploy.sh",  # optional; path this task intends to touch
         "depends_on": ["t2", "t3"],    # optional; task ids that must finish before this one is
                                         #   dispatched (also auto-inferred from other task ids
                                         #   literally referenced in "prompt" — see infer_deps())
         "dry_verdict": "HOLDS"}        # --dry-run only: HOLDS|FAILS|INCONCLUSIVE
      ]
    }

The driver never asks an LLM to decide accept/reject or to summarize between
waves; those are computed from the wire verdict files by code below.
"""
import argparse, concurrent.futures as cf, fnmatch, hashlib, json, os, re, shutil, subprocess, sys, tempfile, time

sys.path.insert(0, os.path.dirname(os.path.abspath(__file__)))
import _cache_lib as cache  # noqa: E402  — the librarian's storage primitives (get/set/fetch)

REPO_ROOT = os.path.dirname(os.path.dirname(os.path.abspath(__file__)))
WIRE_DIR = os.path.join(REPO_ROOT, "wire")
AGENTS_DIR = os.path.join(REPO_ROOT, ".claude", "agents")
WIRE = os.path.join(REPO_ROOT, "bin", "wire")
RUN_STATE_FILE = os.path.join(WIRE_DIR, ".run_state.json")
# A real code-review diff is at most a few thousand lines. A candidate base ref that produces
# more than this is almost certainly a stale local remote-tracking branch (unfetched for weeks/
# months), not the actual PR base — cache that and every downstream persona reviews noise.
MAX_PRECOMPUTE_DIFF_BYTES = 5_000_000


def load_run_state():
    try:
        return json.load(open(RUN_STATE_FILE, encoding="utf-8"))
    except (FileNotFoundError, json.JSONDecodeError):
        return {}


def task_fingerprint(task):
    """Hash of a task's own content — nothing about run history. Guards idempotent reuse
    against a stale verdict: if a plan.json is hand-edited (or a --goal is re-authored) so task
    id "t1" now means different work, the fingerprint won't match and the driver re-runs it
    instead of silently reusing a verdict for content that no longer exists."""
    # Exclude runtime-injected keys (_model/_wt/_cwd/_system, set by preflight_roll_call/
    # process_task) — otherwise the fingerprint saved after a task runs (mutated dict) would
    # never match the pristine one recomputed from a freshly-loaded plan.json next run,
    # permanently defeating reuse.
    visible = {k: v for k, v in task.items() if not k.startswith("_")}
    return hashlib.sha256(json.dumps(visible, sort_keys=True).encode()).hexdigest()[:16]


def save_run_state(state):
    os.makedirs(WIRE_DIR, exist_ok=True)
    json.dump(state, open(RUN_STATE_FILE, "w", encoding="utf-8"), indent=2)


RUN_LOCK = os.path.join(WIRE_DIR, ".run.lock")


def acquire_run_lock():
    """Refuse to start a second bin/run against the same wire/ while one is already live.
    `wire clear` (called once, at the top of every run) archives the *entire* prior file set —
    if a first run's persona subprocesses are still writing wire/<id>.result.md directly (they
    write straight to disk, not through bin/wire, so bin/wire's own claim-lock never sees them),
    a second run's clear can sweep those in-flight files into its own archive dir mid-write.
    The first run's later verify/gate reads then see missing files and reject good work purely
    from the race, not from anything about the reviewed content — confirmed live during this
    framework's own self-test dogfooding. This is a whole-run guard, not just a `clear` lock."""
    os.makedirs(WIRE_DIR, exist_ok=True)
    if os.path.exists(RUN_LOCK):
        try:
            holder = int(open(RUN_LOCK, encoding="utf-8").read().strip())
            os.kill(holder, 0)   # no exception -> holder process is alive
            sys.exit(f"bin/run: another run is already active against {WIRE_DIR} "
                     f"(pid {holder}) — refusing to start concurrently; wait for it to finish "
                     f"or remove {RUN_LOCK} if that pid is confirmed dead")
        except (OSError, ValueError):
            pass   # stale lock (holder gone, or unreadable) — safe to reclaim
    with open(RUN_LOCK, "w", encoding="utf-8") as f:
        f.write(str(os.getpid()))


def release_run_lock():
    try:
        os.remove(RUN_LOCK)
    except FileNotFoundError:
        pass


VALID_PERSONAS = {"conductor", "composer", "luthier", "soloist", "critic",
                  "tuner", "heckler", "scribe"}

# Two tiers, one default: every persona runs on the same model unless a --model/--premium-model
# flag or a task's own "model" field says otherwise. Sonnet 5 by default for everyone — the
# conductor/scribe "premium" tier only needs to be a DIFFERENT (e.g. stronger) model when a run
# calls for it; most runs don't.
DEFAULT_MODEL = "claude-sonnet-5"


def log(msg):
    print(f"\033[2m[run]\033[0m {msg}", file=sys.stderr, flush=True)


def persona_body(name):
    """The system prompt for a persona is its agent .md with YAML frontmatter stripped."""
    path = os.path.join(AGENTS_DIR, f"{name}.md")
    text = open(path, encoding="utf-8").read()
    if text.startswith("---"):
        text = text.split("---", 2)[-1]
    return text.strip()


def wire_state(task_id, role, state):
    """The DRIVER owns the manifest — agents never touch it. Deterministic, ~free.

    "claimed" and the terminal states (done/accepted/rejected/blocked) are two different
    bin/wire subcommands with different arities ("claim <id> <role>" vs "status <id> <state>",
    the latter deriving owner from the earlier claim) — every call here used to go through
    "status" with a bogus 3-arg form, which bin/wire rejects ("bad state: <role>") and which
    capture_output=True + check=False silently swallowed. wire/manifest.md has been getting zero
    state lines from any run as a result."""
    if state == "claimed":
        cmd = [WIRE, "claim", task_id, role]
    else:
        cmd = [WIRE, "status", task_id, state]
    proc = subprocess.run(cmd, cwd=REPO_ROOT, check=False, capture_output=True, text=True)
    if proc.returncode != 0:
        log(f"{task_id}: manifest write failed ({' '.join(cmd[1:])}): "
            + (proc.stdout or proc.stderr or "").strip()[:200])


def context_brief_note():
    """Point the caller at whatever shared-context cache entries already exist for this run —
    written either by the driver's own zero-LLM-cost precompute_context_cache() (see below) or
    by the composer — so every task reuses them instead of re-deriving/re-fetching the same
    PRD read, diff, or PR metadata every other arm would otherwise repeat identically. Each
    entry is independent (a run without network access may have diff.patch but no pr.json) —
    mention only the ones that actually exist. Empty string (no-op) when nothing is cached yet.

    Called from build_system_prompt() so it lands on EVERY stage's system prompt (result,
    coverage-gate, verify) — it used to be appended only to the verify/coverage-gate user
    prompts, which left the main result-stage call with zero mention of the cache. A live
    canary caught the consequence directly: the composer's result-stage call had no cache
    pointer at all, ran its own `git diff` against a merge-base that turned out stale, and
    produced a 73,670-file diff instead of the real ~23-file one — while the SAME run's
    error-handling task, whose verify prompt DID carry this note, read the cache correctly
    and got the clean diff for $0. Worded as a hard MUST, not a suggestion: prose guidance a
    persona doc merely recommends is easy to skip under task pressure."""
    parts = []
    if os.path.exists(os.path.join(WIRE_DIR, "context.md")):
        parts.append("`wire/context.md` (shared PRD/diff/changed-files context brief)")
    if cache.has(WIRE_DIR, "diff.patch"):
        parts.append("`wire/cache/diff.patch` (the full raw diff, already fetched)")
    if cache.has(WIRE_DIR, "changed-files.txt"):
        parts.append("`wire/cache/changed-files.txt` (changed-file list with status, already computed)")
    if cache.has(WIRE_DIR, "pr.json"):
        parts.append("`wire/cache/pr.json` (cached PR metadata, already fetched)")
    if not parts:
        return ""
    return (
        "\n\n## Cache — read this before touching git/gh\n"
        "This run already has cached context: " + ", ".join(parts) + ". "
        "You MUST read these first (`bin/cache get <key>` or read the `wire/cache/` file "
        "directly) and MUST NOT run your own `git diff`/`git log`/`gh pr view`/`gh api` to "
        "re-derive the same content — not \"prefer the cache\", an outright rule. A prior run "
        "ignored this and re-ran `git diff` against a stale local ref, producing a "
        "73,670-file diff instead of the real ~23-file change; reading the cache instead "
        "avoids that failure mode entirely, at zero cost, every time. If a cache entry is "
        "missing or looks visibly wrong for this task (empty, truncated, wrong repo), say so "
        "explicitly in your result rather than silently re-deriving it yourself."
    )


def precompute_context_cache(plan, dry_run):
    """Push the diff/changed-files/PR-metadata fetch out of the (paid, LLM) composer and into
    plain deterministic code, run ONCE before any agent is spawned — the driver already has
    `target_repo` in hand, and a `git diff`/`gh pr view` is exactly the kind of fetch that
    doesn't need a model at all. Every task that would otherwise re-run this itself (or wait on
    a composer call to do it) gets it for the cost of a subprocess instead of a turn.

    Deliberately bounded to what's safely derivable from the plan with no guessing:
    - the diff needs a merge-base, which needs a base ref — use plan['base_ref'] if given,
      else probe a short list of common upstream names (origin/main, origin/dev, ...) and use
      the first that actually merge-bases cleanly against HEAD.
    - PR metadata needs `gh` installed AND the checkout to have an associated PR AND network
      egress to actually reach the GitHub API — any of those can be absent in a sandbox, so this
      is wrapped to fail silently and fall back to the composer/soloist fetching it themselves.

    Never fatal: this is pure optimization layered on top of a working fallback path (the
    composer/soloist personas still know how to fetch this themselves if the cache is empty),
    so any exception here is logged and swallowed, never raised."""
    if dry_run:
        return
    target_repo = plan.get("target_repo")
    if not target_repo or not os.path.isdir(target_repo):
        return

    if not cache.has(WIRE_DIR, "diff.patch"):
        candidates = [plan["base_ref"]] if plan.get("base_ref") else [
            "origin/main", "origin/master", "origin/dev", "main", "master", "dev"]
        for base_ref in candidates:
            try:
                mb = subprocess.run(["git", "-C", target_repo, "merge-base", "HEAD", base_ref],
                                     capture_output=True, text=True, timeout=15)
                if mb.returncode != 0 or not mb.stdout.strip():
                    continue
                merge_base = mb.stdout.strip()
                diff = subprocess.run(["git", "-C", target_repo, "diff", f"{merge_base}...HEAD"],
                                       capture_output=True, timeout=60)
                if diff.returncode != 0 or not diff.stdout.strip():
                    continue
                if len(diff.stdout) > MAX_PRECOMPUTE_DIFF_BYTES:
                    # A merge-base against a stale local remote-tracking ref (e.g. `origin/main`
                    # not fetched in months) produces a diff that's the whole intervening history,
                    # not the actual change under review — caching that as ground truth is worse
                    # than not caching anything, since a persona reading it would review the wrong
                    # thing. Try the next candidate instead of trusting this one.
                    log(f"precompute diff vs {base_ref}: {len(diff.stdout)} bytes exceeds "
                        f"{MAX_PRECOMPUTE_DIFF_BYTES} — looks like a stale/wrong base ref, skipping")
                    continue
                cache.set_bytes(WIRE_DIR, "diff.patch", diff.stdout)
                log(f"precomputed wire/cache/diff.patch vs {base_ref} "
                    f"({len(diff.stdout)} bytes, $0.00 — no LLM call)")
                names = subprocess.run(["git", "-C", target_repo, "diff", "--name-status",
                                         f"{merge_base}...HEAD"], capture_output=True, timeout=30)
                if names.returncode == 0 and names.stdout.strip():
                    cache.set_bytes(WIRE_DIR, "changed-files.txt", names.stdout)
                    log("precomputed wire/cache/changed-files.txt ($0.00 — no LLM call)")
                break
            except Exception as e:
                log(f"precompute diff (base_ref={base_ref}): skipped ({e})")

    if not cache.has(WIRE_DIR, "pr.json") and shutil.which("gh"):
        try:
            pr = subprocess.run(
                ["gh", "pr", "view", "--json", "number,title,body,baseRefName,headRefName,url"],
                cwd=target_repo, capture_output=True, text=True, timeout=15)
            if pr.returncode == 0 and pr.stdout.strip():
                cache.set_text(WIRE_DIR, "pr.json", pr.stdout)
                log("precomputed wire/cache/pr.json ($0.00 — no LLM call)")
        except Exception as e:
            log(f"precompute PR metadata: skipped ({e})")


# ---- leaf execution: the ONLY place an LLM is spawned --------------------------

def _log_failure(label, proc):
    """A failed/uninterpretable claude -p call should leave a diagnostic trail, not just
    a silent zero-cost guess — this is what let a $5.31 conductor call vanish with no clue why."""
    out = (proc.stdout or "").strip()[:800]
    err = (proc.stderr or "").strip()[:800]
    log(f"{label}: no parseable cost (exit {proc.returncode})")
    if out:
        log(f"{label} stdout (truncated): {out}")
    if err:
        log(f"{label} stderr (truncated): {err}")


ROLLCALL_CAP_USD = 0.75


def roll_call(task_id, artifact, cwd, model, system):
    """Dedicated up-front comprehension check, run BEFORE the real work call. An earlier
    version asked the agent to echo a RESTATE line inside its own final response alongside
    doing the real task, but that was silent almost every time — a persona's final message
    doesn't reliably repeat an early-turn aside. A separate call is the only reliable way to
    catch a misread task id/artifact/cwd before spending real budget.

    Uses the SAME model and system prompt (persona doc + driver-contract override) the real
    call would get — a cheaper model or a bare prompt wouldn't exercise the persona doc's own
    conflicting conventions (e.g. composer's "write to wire/context.md"), which is exactly what
    the original bug was. A one-line echo stays cheap even on the real model tier.

    Returns (cost_usd, status, reason) where status is one of:
      "ok"       — echoed back exactly what it was given; safe to proceed.
      "error"    — the check itself didn't run cleanly (bad JSON, no RESTATE line at all,
                   cap exceeded). This says nothing about whether the real task would have
                   succeeded, so the caller should fail OPEN (proceed with a warning) rather
                   than block real work over a flaky echo call.
      "mismatch" — it ran fine and echoed back the WRONG coordinates. This is a genuine
                   comprehension failure and is the only status worth hard-blocking on."""
    prompt = (
        f"Before starting any real work, restate your assignment. Reply with ONLY this "
        f"exact line, no other words, no tool calls, no file writes:\n"
        f"RESTATE task={task_id} artifact={artifact} cwd={cwd}"
    )
    cmd = ["claude", "-p", prompt,
           "--append-system-prompt", system,
           "--output-format", "json",
           "--model", model,
           "--permission-mode", "acceptEdits",
           "--max-budget-usd", f"{ROLLCALL_CAP_USD:.2f}"]
    proc = subprocess.run(cmd, cwd=cwd, capture_output=True, text=True)
    try:
        parsed = json.loads(proc.stdout)
    except Exception:
        return (0.0, "error", "roll call: claude call returned no parseable JSON")
    cost = float(parsed.get("total_cost_usd", 0.0))
    if parsed.get("subtype") == "error_max_budget_usd":
        return (cost, "error", f"roll call: hit ROLLCALL_CAP_USD (${ROLLCALL_CAP_USD:.2f}) before "
                                f"producing a RESTATE line — the cap may be too tight, not a flaky echo")
    m = RESTATE_RE.search(str(parsed.get("result", "")))
    if m is None:
        return (cost, "error", "roll call: no RESTATE line in response")
    r_task, r_artifact, r_cwd = m.groups()
    # Compare cwd via realpath — macOS resolves /var/folders/... (what tempfile.mkdtemp()
    # returns) through a symlink to /private/var/folders/..., and a persona that inspects its
    # own location (e.g. via a tool call, despite being asked not to) may report the resolved
    # form. Same directory, different string; a raw != would call it a false mismatch.
    if r_task != task_id or r_artifact != artifact or os.path.realpath(r_cwd) != os.path.realpath(cwd):
        return (cost, "mismatch",
                f"roll call mismatch — echoed task={r_task} artifact={r_artifact} cwd={r_cwd} "
                f"(expected task={task_id} artifact={artifact} cwd={cwd})")
    return (cost, "ok", None)


def build_system_prompt(persona, artifact, cwd):
    """The driver-contract system prompt a persona runs under: its own doc plus the override
    text telling it where to actually write and (if isolated) that its cwd is already a local
    checkout. Extracted so the preflight roll-call phase can build the EXACT same prompt a
    task will really run under, before spending anything on the real call.

    Includes context_brief_note() so the cache pointer lands on EVERY stage's system prompt,
    not just verify/coverage-gate's user prompt — see that function's docstring for why the
    result-stage call (which used to get none of this) is exactly where a live run's cache
    bypass happened."""
    system = persona_body(persona) + context_brief_note() + (
        f"\n\n## Driver contract (Achtopus)\n"
        f"You are running under the deterministic driver. Write your entire deliverable to the "
        f"absolute path `{artifact}` — and ONLY that path. This OVERRIDES any other output "
        f"filename your persona description above mentions (e.g. composer's own instructions "
        f"say to write `wire/context.md` — under the driver, ignore that and use `{artifact}` "
        f"instead; the driver, not the persona doc, decides the artifact name per task so "
        f"downstream tasks can find it by task id). Do NOT edit wire/manifest.md or run "
        f"bin/wire — the driver records all state. Coordinate only through files under "
        f"`{WIRE_DIR}`."
    )
    if cwd != REPO_ROOT:
        # cwd here is either the shared target_repo or a worktree isolated from it — either way
        # it's already a local, checked-out copy. A task's own prompt may still say "clone" or
        # "fetch" out of habit (e.g. a conductor-authored prompt written before this repo access
        # was wired up) — override that explicitly so agents don't burn time/egress re-fetching
        # something already sitting in their own working directory.
        system += (
            f"\n\nYour working directory `{cwd}` is ALREADY a local checkout of the target "
            f"repo — do not `git clone`, `git fetch` from a remote, or use `gh` to re-fetch "
            f"anything you can already read/run locally (`git diff`, `git log`, `git show`, "
            f"reading files, running tests) from this directory as-is."
        )
    return system


def run_agent(persona, prompt, task_id, artifact_suffix, model, cwd, dry=None, max_usd=None,
              precomputed=None):
    """Spawn one persona agent headless; return (cost_usd, ok). The agent writes its
    artifact to an ABSOLUTE wire path — it does no coordination, only its own work.
    `max_usd`, when given, is a HARD per-call spend cap (--max-budget-usd) — the pre-spawn
    budget governor in process_task is only a projection; this is the backstop that actually
    stops a single runaway call from blowing past it.

    `precomputed`, when given, is a (system, rc_cost) tuple from preflight_roll_call — reused
    instead of rebuilt.

    Without it (verify/coverage/scribe calls), this builds its own system prompt and pays NO
    separate roll-call round trip. A dedicated echo-and-check `claude -p` call was originally
    fired here too, once per coverage-gate call and once per verify call (so a single task with
    `verify: pair` paid for FOUR roll calls: preflight's main-task check, then one more each for
    critic/tuner/heckler) — a live $20-budget run measured this reserving ~$19.54 in roll-call +
    projected cost before most real work had even happened, starving `security`/`synthesize`
    entirely. Those downstream calls run in the SAME cwd the main task's roll call already
    validated (same task id, same worktree-or-REPO_ROOT), and the only thing left to verify —
    "did it write to the artifact path the driver dictated, not its persona doc's own habit" —
    is already checked for free by `ok = os.path.exists(artifact)` a few lines below: a persona
    that writes to the wrong place fails closed (INCONCLUSIVE / no-result), it doesn't silently
    pass. Paying for a second confirmatory round trip on top of a check that already exists is
    the double charge; cut here instead of adding more coverage to the same risk."""
    artifact = os.path.join(WIRE_DIR, f"{task_id}.{artifact_suffix}")
    if dry is not None:
        # Deterministic stub: exercise the orchestration without any API cost.
        with open(artifact, "w", encoding="utf-8") as f:
            f.write(dry["body"])
        return (dry.get("cost", 0.0), True)

    if precomputed is not None:
        system, rc_cost = precomputed
    else:
        system = build_system_prompt(persona, artifact, cwd)
        rc_cost = 0.0

    cmd = ["claude", "-p", prompt,
           "--append-system-prompt", system,
           "--output-format", "json",
           "--model", model,
           "--permission-mode", "acceptEdits",
           "--add-dir", WIRE_DIR]
    if cwd != REPO_ROOT:
        cmd += ["--add-dir", cwd]
    if max_usd is not None:
        cmd += ["--max-budget-usd", f"{max(max_usd, 0.01):.2f}"]
    proc = subprocess.run(cmd, cwd=cwd, capture_output=True, text=True)
    cost = 0.0
    parsed = None
    try:
        parsed = json.loads(proc.stdout)
        cost = float(parsed.get("total_cost_usd", 0.0))
    except Exception:
        _log_failure(task_id, proc)
    ok = os.path.exists(artifact)
    if not ok and persona == "composer":
        # composer's own persona doc (docs/patterns.md, .claude/agents/composer.md) says to
        # write wire/context.md — a strongly-repeated convention from non-driver coordination
        # mode that can win over the driver contract's told-you-once artifact path even after
        # the contract was made explicit about overriding it. Recover the real work instead of
        # burning the spend for nothing: if it landed at the conventional path, adopt it.
        legacy = os.path.join(WIRE_DIR, "context.md")
        if os.path.exists(legacy):
            shutil.copyfile(legacy, artifact)
            ok = True
            log(f"{task_id}: composer wrote wire/context.md instead of {artifact} — recovered, copied over")
    # A real spend with no artifact is still a failure needing a diagnostic trail — don't
    # rely solely on the JSON-parse-exception path above, which never fires when the call
    # succeeds cleanly but the agent just didn't write its file (e.g. it hit max turns, was
    # denied a permission, or replied in prose instead of writing). Parse failures already
    # got their trail from _log_failure in the except block above; only log here for the
    # complementary case (parsed fine, no artifact) to avoid double-logging the same call.
    if not ok and parsed is not None:
        log(f"{task_id}: claude call succeeded (${cost:.3f}) but wrote no artifact at {artifact}")
        result_text = str(parsed.get("result", ""))[:800]
        if result_text:
            log(f"{task_id} result (truncated): {result_text}")
        subtype = parsed.get("subtype")
        if subtype and subtype != "success":
            log(f"{task_id}: subtype={subtype}")
    return (cost + rc_cost, ok)


# ---- worktree isolation: handed to the agent, not left to a prose rule ---------

def make_worktree(target_repo, task_id):
    wt = tempfile.mkdtemp(prefix=f"achtopus-{task_id}-")
    r = subprocess.run(["git", "-C", target_repo, "worktree", "add", "--detach", wt],
                       capture_output=True, text=True)
    if r.returncode != 0:
        log(f"{task_id}: worktree add failed, falling back to shared checkout: {r.stderr.strip()}")
        shutil.rmtree(wt, ignore_errors=True)
        return None
    return wt


def remove_worktree(target_repo, wt):
    subprocess.run(["git", "-C", target_repo, "worktree", "remove", "--force", wt],
                   capture_output=True, text=True)
    shutil.rmtree(wt, ignore_errors=True)


def preflight_roll_call(tasks, plan, dry_run, concurrency):
    """Roll-call every task in the plan before any real dispatch begins, ignoring dependency
    order (comprehension doesn't depend on other tasks having run). Each check runs on the
    exact (persona, model, cwd, system-prompt) tuple the task will get for real; isolate tasks
    get their worktree created here so the check validates the real cwd, and process_task
    reuses it via task['_wt']/['_cwd'] instead of creating a second one.

    Mutates each task dict with _cwd/_wt/_model/_system for reuse. Returns total
    preflight spend. Aborts the whole run (cleaning up worktrees) on any genuine MISMATCH; a
    roll call that merely errored doesn't abort — that's not evidence the real call would."""
    if dry_run:
        return 0.0
    log(f"roll call: checking {len(tasks)} task(s) before any real dispatch")
    for t in tasks:
        tid = t["id"]
        t["_model"] = t.get("model", plan.get("default_model", DEFAULT_MODEL))
        cwd = REPO_ROOT
        if t.get("isolate") and plan.get("target_repo"):
            wt = make_worktree(plan["target_repo"], tid)
            t["_wt"] = wt
            cwd = wt or REPO_ROOT
        t["_cwd"] = cwd
        t["_system"] = build_system_prompt(t["persona"], os.path.join(WIRE_DIR, f"{tid}.result.md"), cwd)

    total_cost = 0.0
    mismatches = []
    with cf.ThreadPoolExecutor(max_workers=concurrency) as ex:
        futs = {ex.submit(roll_call, t["id"], os.path.join(WIRE_DIR, f"{t['id']}.result.md"),
                           t["_cwd"], t["_model"], t["_system"]): t
                for t in tasks}
        for fut in cf.as_completed(futs):
            t = futs[fut]
            cost, status, reason = fut.result()
            total_cost += cost
            if status == "mismatch":
                mismatches.append((t["id"], reason))
                log(f"{t['id']}: roll call MISMATCH — {reason}")
            elif status == "error":
                log(f"{t['id']}: {reason} (roll call inconclusive, not blocking)")
            else:
                log(f"{t['id']}: roll call ok")

    if mismatches:
        for t in tasks:
            if t.get("_wt"):
                remove_worktree(plan["target_repo"], t["_wt"])
        sys.exit(f"roll call failed for {len(mismatches)} task(s) before any real work was "
                 f"dispatched (${total_cost:.3f} spent on checks): " +
                 "; ".join(f"{tid}: {reason}" for tid, reason in mismatches))
    log(f"roll call: all {len(tasks)} task(s) clear (${total_cost:.3f}) — dispatching")
    return total_cost


# ---- the programmatic gate: NO LLM decides accept/reject -----------------------

VERIFY_PLANS = {
    "none":    [],
    "single":  [("tuner", "confirm")],
    "pair":    [("tuner", "confirm"), ("heckler", "refute")],
    # Odd N, MIXED voters — a quorum of identical tuner-confirm calls has zero heckler
    # diversity (each voter attacks the same failure mode). Mix confirm/refute so the
    # panel attacks distinct failure modes, per docs/protocol.md G5 and docs/patterns.md.
    "quorum3": [("tuner", "confirm"), ("tuner", "confirm"), ("heckler", "refute")],
    "quorum5": [("tuner", "confirm"), ("tuner", "confirm"), ("tuner", "confirm"),
                ("heckler", "refute"), ("heckler", "refute")],
}


PLACEHOLDER_RE = re.compile(r"\b(TODO|TBD|FIXME|PLACEHOLDER|XXX)\b", re.I)


CMD_VERBS_RE = re.compile(
    r"`\s*(?:grep|git|curl|npm|yarn|npx|jest|pytest|sed|awk|find|python3?|node|ls|cat|go)\b[^`\n]*`"
)


RESTATE_RE = re.compile(r"(?m)^RESTATE\s+task=(\S+)\s+artifact=(\S+)\s+cwd=(\S+)")


def _evidence(text):
    """Proof-of-work signals in a verdict artifact (evidence-gate). Returns
    (has_placeholder, has_command). A logged command = a fenced block, a `$ `/`> ` line, or an
    inline single-backtick span that STARTS with a known CLI verb (grep/git/npm/...) — this last
    form was added after a live run showed a genuinely thorough, real verification (re-ran the
    report's own grep, read 4 source files with line numbers) get discarded as INCONCLUSIVE
    because it quoted its commands in prose with inline backticks instead of a fenced block.
    Deliberately narrow: a backtick span merely citing a file PATH (no command verb) still does
    NOT count — that would let a static-only citation masquerade as executed proof, defeating the
    gate's actual purpose (a verb-anchored match means an actual command was quoted, not just a
    reference to where in the code something lives)."""
    text = text or ""
    has_placeholder = bool(PLACEHOLDER_RE.search(text)) or not text.strip()
    has_command = (bool(re.search(r"```", text))
                   or bool(re.search(r"(?m)^[ \t]*[$>][ \t]+\S", text))
                   or bool(CMD_VERBS_RE.search(text)))
    return has_placeholder, has_command


def classify(text, kind):
    """Parse a verdict/refute file AND apply the evidence gate. kind='confirm' ->
    HOLDS/FAILS/INCONCLUSIVE (+tier); kind='refute' -> SURVIVES/REFUTED.

    Evidence is required to PASS, never to fail: a HOLDS/SURVIVES that logs no command (or
    that claims `executed` with no command, or contains a placeholder) is downgraded to
    INCONCLUSIVE — which never accepts. This attacks the weak/static-drift verifier that
    writes 'HOLDS(executed)' without having run anything. FAILS/REFUTED are never downgraded
    (rejecting to the owner is the safe direction)."""
    t = (text or "").upper()
    placeholder, has_cmd = _evidence(text)
    if kind == "confirm":
        tier = "executed" if "EXECUTED" in t else ("static" if "STATIC" in t else "untagged")
        if re.search(r"\bFAILS\b", t):
            return ("FAILS", tier)
        if re.search(r"\bHOLDS\b", t):
            # gate: a claimed pass must be earned. static may skip the command (it's explicitly
            # no-execution) but not the placeholder/empty check; executed/untagged need a command.
            if placeholder or (tier != "static" and not has_cmd):
                return ("INCONCLUSIVE", tier)
            return ("HOLDS", tier)
        return ("INCONCLUSIVE", tier)
    else:
        if re.search(r"\bREFUTED\b", t):
            return ("REFUTED", None)
        if re.search(r"\bSURVIVES\b", t):
            if placeholder or not has_cmd:   # a clearance with no attack logged isn't a clearance
                return ("INCONCLUSIVE", None)
            return ("SURVIVES", None)
        return ("INCONCLUSIVE", None)


def decide(verdicts):
    """verdicts: list of (kind, verdict, tier). Returns (accepted, reason). Pure code —
    this is the accept/reject a prose conductor used to fudge.

    A "pass" is HOLDS from a confirmer (tuner) or SURVIVES from a refuter (heckler) — the
    same underlying question either scale asks: did this voter clear the claim. For N<=2
    (single/pair) every voter must pass (unanimity). For N>=3 (quorum) voters are a MIXED
    panel of tuner+heckler attacking distinct failure modes (see VERIFY_PLANS), and this is
    the same rule extended past N=2: unanimity at N=2 already equals strict majority
    (>1 of 2 requires both), quorum just lets N>=3 pass on a non-unanimous majority."""
    if not verdicts:
        return (True, "no-verify (low-stakes: auto-accepted)")
    if any(v == "INCONCLUSIVE" for _, v, _ in verdicts):
        return (False, "INCONCLUSIVE verdict — not cleared (blocked, per protocol G4)")

    n = len(verdicts)
    if n >= 3:  # quorum: strict majority of passes across the mixed confirm/refute panel
        passing = sum(1 for _, v, _ in verdicts if v in ("HOLDS", "SURVIVES"))
        if passing > n / 2:
            return (True, f"quorum {passing}/{n} passing (mixed confirm/refute)")
        return (False, f"quorum failed ({passing}/{n} passing)")

    # single or pair: every confirmer must HOLD (and any heckler must SURVIVE)
    confirms = [v for v in verdicts if v[0] == "confirm"]
    refutes = [v for v in verdicts if v[0] == "refute"]
    if any(v == "REFUTED" for _, v, _ in refutes):
        return (False, "heckler REFUTED the claim")
    if all(v == "HOLDS" for _, v, _ in confirms) and all(v == "SURVIVES" for _, v, _ in refutes):
        tiers = {tier for k, v, tier in confirms}
        note = "HOLDS(static only)" if tiers == {"static"} else "HOLDS"
        return (True, f"{note}" + (" + SURVIVES" if refutes else ""))
    return (False, "a confirmer did not return HOLDS")


RATING_RE = re.compile(r"RATING:\s*(red|warning|green)", re.I)


def extract_rating(text):
    """Parse the rating marker convention (docs/report-template.md / docs/prr.md): a
    result artifact should start its rating with 'RATING: red|warning|green', or carry
    the equivalent 🔴/⚠️/✅ emoji. Returns 'red'/'warning'/'green' or None if no marker
    is present (i.e. this task's result isn't PRR-shaped)."""
    m = RATING_RE.search(text or "")
    if m:
        return m.group(1).lower()
    if "🔴" in (text or ""):
        return "red"
    if "⚠️" in (text or ""):
        return "warning"
    if "✅" in (text or ""):
        return "green"
    return None


def tally_scorecard(results):
    """Deterministic scorecard tally + launch-rule verdict — a sibling to decide(): pure
    code, same reasoning docs/prr.md describes ("the scribe tallies the scorecard and
    applies the launch rule") but computed here instead of reasoned out by an LLM. Scans
    each ACCEPTED task's wire/<id>.result.md for a rating marker (see extract_rating) and
    applies the mechanical "no red at launch" rule:
      any red -> NO-GO; no red but any warning -> GO-WITH-CONDITIONS; all green -> GO.
    Returns None (never raises) when no accepted result carries a rating marker at all —
    i.e. this isn't a PRR-shaped plan — so callers can skip the summary line gracefully."""
    counts = {"red": 0, "warning": 0, "green": 0}
    rated = 0
    for r in results:
        if r.get("outcome") != "accepted":
            continue
        path = os.path.join(WIRE_DIR, f"{r['id']}.result.md")
        if not os.path.exists(path):
            continue
        try:
            text = open(path, encoding="utf-8").read()
        except OSError:
            continue
        rating = extract_rating(text)
        if rating is None:
            continue
        counts[rating] += 1
        rated += 1
    if rated == 0:
        return None
    if counts["red"] > 0:
        verdict = "NO-GO"
    elif counts["warning"] > 0:
        verdict = "GO-WITH-CONDITIONS"
    else:
        verdict = "GO"
    return {"counts": counts, "n_domains": rated, "verdict": verdict}


# ---- coverage gate: critic checks rubric coverage BEFORE the tuner/heckler verify pass ---

def run_coverage_gate(task, model, dry_run, max_usd=None):
    """Spawn the critic to check whether the task's result answered every rubric question
    for its domain (docs/prr.md's A-K list) — a coverage gap is its own finding, separate
    from whether individual claims are correct (that stays the tuner/heckler's job). Returns
    (cost, gap_flag, note) where note is a short string surfaced on the task's outcome. This
    does not gate accept/reject on its own; it is a real, invoked step whose output is used,
    not dead weight sitting unwired."""
    tid = task["id"]
    domain_hint = task.get("domain", task["prompt"][:120])
    cprompt = (f"Coverage gate for wire/{tid}.result.md. Domain/claim context: {domain_hint!r}. "
               f"Using the matching domain's rubric questions in docs/prr.md's A-K list, check "
               f"whether the result answered every question for that domain, or whether some "
               f"were silently unaddressed. Do not judge whether the answers given are correct — "
               f"that is a separate verify step. First line of your report must be exactly "
               f"'COVERAGE: complete' or 'COVERAGE: gaps'.")
    dry = ({"body": "COVERAGE: complete — all rubric questions addressed.\n", "cost": 0.02}
           if dry_run else None)
    cost, ok = run_agent("critic", cprompt, tid, "coverage.md", model, REPO_ROOT, dry, max_usd=max_usd)
    text = ""
    cpath = os.path.join(WIRE_DIR, f"{tid}.coverage.md")
    if os.path.exists(cpath):
        text = open(cpath, encoding="utf-8").read()
    gap = bool(re.search(r"^COVERAGE:\s*gaps", text, re.I | re.M))
    note = ""
    if gap:
        lines = [l.strip() for l in text.splitlines() if l.strip()]
        note = "coverage gap: " + (lines[1] if len(lines) > 1 else "unspecified rubric question(s) unaddressed")
    elif not ok or not text.strip():
        note = "coverage gate did not run / posted nothing"
    return cost, gap, note


# ---- scope governor: a static allowlist check, not a sandbox -------------------

def check_scope(task):
    """Blast-radius guardrail (opt-in, additive). A task MAY declare a 'scope' (list of
    allowed path prefixes/globs, relative to target_repo) alongside a 'target' (the
    path/dir it intends to touch — relevant to luthier/prober tasks that execute real
    commands). If both are present and 'target' is not a subpath of any 'scope' entry,
    refuse before spawning the agent. This is a static string/glob check on declared
    fields, NOT runtime sandboxing — it catches a task whose own stated target is
    outside its declared lane, nothing more.

    Absent 'scope' (or absent 'target'), behavior is unchanged — nothing to check, so
    nothing is enforced; this keeps the governor fully backward compatible."""
    scope = task.get("scope")
    target = task.get("target")
    if not scope or not target:
        return (True, None)
    target_norm = str(target).replace("\\", "/").lstrip("/")
    for pattern in scope:
        p = str(pattern).replace("\\", "/").rstrip("/")
        if (target_norm == p or target_norm.startswith(p + "/")
                or fnmatch.fnmatch(target_norm, p)):
            return (True, None)
    return (False, f"target {target!r} is outside declared scope {scope!r}")


# ---- the coordination loop (deterministic; this is what replaces the LLM) -------

# Real per-call costs vary a lot by persona/stage (a critic coverage-gate call runs well under
# $1; a domain soloist call can run $1-3), but a flat plan-supplied est_agent_usd has to be
# pessimistic enough to cover the most expensive call type or it risks a real overshoot. The
# fallout: a live canary measured est_agent_usd=3.00 against a real per-call average under $1 —
# every task's own admission reserved 3-4x its actual eventual cost, so 6 concurrently-dispatched
# domain tasks alone reserved ~$18 of a $20 budget just entering their first stage, starving
# security/rollout-risk and two verify passes into INCONCLUSIVE rejections despite real total
# spend landing at $17.01.
#
# First fix attempt was a single global running average, gated on 3 samples before trusting it.
# A follow-up live run showed that's not enough — it made outcomes WORSE (4 rejected vs 2): the
# 6 domain tasks' own "result" stage reservations all fire nearly simultaneously right after
# `brief` finishes, so by the time they reserve, only brief's ONE result-stage sample exists —
# nowhere near 3. And once enough samples DO land, a single blended average lets the expensive
# result-stage costs (~$1.2-1.7) drag the reservation for cheap coverage-gate/verify calls
# (~$0.3-0.7, coverage-gate measured at $0.527) up with them, starving those cheap calls even
# though real budget existed for them specifically. Fix: track a separate running average PER
# call kind (result / coverage / verify) so each stage type's reservation reflects only ITS OWN
# real costs, and trust a kind's average after just 1 real sample of that kind — the 6 domain
# tasks' result-stage reservations still start from the static guess (no result-kind sample
# exists until one lands), but their coverage-gate/verify reservations benefit from every
# same-kind call across ALL tasks, not just their own, so they mature fast even under high
# concurrency.
ADAPTIVE_MIN_SAMPLES = 1
ADAPTIVE_SAFETY_MARGIN = 1.5
ADAPTIVE_FLOOR_USD = 0.05


def reserved_estimate(spend, plan, kind):
    """The amount to reserve for the NEXT call of this `kind` ("result" | "coverage" | "verify"),
    computed atomically with the admission check (must be called with `lock` already held — see
    the concurrency-race note in process_task). Starts from the plan's flat est_agent_usd for a
    kind until ADAPTIVE_MIN_SAMPLES real costs of THAT kind have landed this run, then switches
    to max(kind_running_average * ADAPTIVE_SAFETY_MARGIN, ADAPTIVE_FLOOR_USD)."""
    bucket = spend.setdefault("kinds", {})
    n, total = bucket.get(kind, (0, 0.0))
    if n < ADAPTIVE_MIN_SAMPLES:
        return plan.get("est_agent_usd", 0.15)
    avg = total / n
    return max(avg * ADAPTIVE_SAFETY_MARGIN, ADAPTIVE_FLOOR_USD)


def record_actual_cost(spend, cost, kind):
    """Feed a real, reconciled call cost into the per-kind running average reserved_estimate()
    reads. Must be called with `lock` already held, right alongside the spend["usd"] reconciliation."""
    bucket = spend.setdefault("kinds", {})
    n, total = bucket.get(kind, (0, 0.0))
    bucket[kind] = (n + 1, total + cost)


def process_task(task, plan, spend, budget, dry_run, lock):
    tid = task["id"]
    model = task.get("model", plan.get("default_model", DEFAULT_MODEL))

    # Scope governor — refuse before spawning if the task's own declared target falls
    # outside its declared allowlist. Cheap, so it runs before the budget check.
    scope_ok, scope_reason = check_scope(task)
    if not scope_ok:
        log(f"{tid}: BLOCKED — scope governor ({scope_reason})")
        wire_state(tid, task["persona"], "blocked")
        return {"id": tid, "outcome": "scope-blocked", "reason": scope_reason, "cost": 0.0}

    # Budget governor — a HARD refusal, the thing prose never enforced.
    # Reserve `est` atomically with the check (not just check-then-later-add-actual-cost):
    # with concurrency > 1, several tasks can each check spend["usd"] against a still-stale
    # value (none of the others' real cost has landed yet) and all pass, then all spend their
    # real cost, overshooting budget by however many tasks were admitted in that window (seen
    # live: a $20 cap ran to $22.29 because 2-3 tasks were admitted concurrently off the same
    # stale spend snapshot). Reserving immediately makes each admission visible to the next
    # concurrent check; the reservation is reconciled against the real cost once known.
    # `est` is recomputed fresh (reserved_estimate) at every stage below rather than fixed once
    # per task — see the note above reserved_estimate() for why a single flat guess starves
    # later-dispatched tasks.
    with lock:
        est = reserved_estimate(spend, plan, "result")
        if spend["usd"] + est > budget:
            log(f"{tid}: SKIPPED — budget governor ({spend['usd']:.2f}+{est:.2f} > {budget:.2f})")
            wire_state(tid, task["persona"], "blocked")
            return {"id": tid, "outcome": "budget-skipped", "cost": 0.0}
        spend["usd"] += est

    # cwd/worktree/system were already resolved by preflight_roll_call() (dry runs skip it, so
    # these keys are absent and we fall back to the old defaults). Its roll-call cost is
    # already folded into spend["usd"] as a lump sum in _main_body, so pass 0.0 here — not
    # task["_rc_cost"] — to avoid counting it twice.
    cwd = task.get("_cwd", REPO_ROOT)
    wt = task.get("_wt")
    precomputed = (task["_system"], 0.0) if "_system" in task else None

    try:
        wire_state(tid, task["persona"], "claimed")
        dry = {"body": f"{tid} result (dry-run stub)\n", "cost": 0.05} if dry_run else None
        with lock:
            headroom = max(budget - spend["usd"], est)
        try:
            cost, ok = run_agent(task["persona"], task["prompt"], tid, "result.md", model, cwd, dry,
                                  max_usd=headroom, precomputed=precomputed)
        except Exception:
            # An exception here (not a normal ok=False) means the reservation below would never
            # get reconciled, permanently inflating spend["usd"] — undo it before propagating.
            with lock:
                spend["usd"] -= est
            raise
        with lock:
            spend["usd"] += cost - est   # reconcile: replace the reservation with the real cost
            record_actual_cost(spend, cost, "result")
        if not ok:
            wire_state(tid, task["persona"], "blocked")
            return {"id": tid, "outcome": "no-result", "cost": cost}
        wire_state(tid, task["persona"], "done")

        # Coverage gate — critic checks rubric coverage BEFORE tuner/heckler verify.
        # A gap is a note on the outcome, not a block: tuner/heckler still own accept/reject.
        coverage_note = ""
        with lock:
            est = reserved_estimate(spend, plan, "coverage")
            room = spend["usd"] + est <= budget
            if room:
                spend["usd"] += est          # reserve atomically with the check — see note above
                ccap = max(budget - spend["usd"], est)
        if room:
            try:
                ccost, gap, coverage_note = run_coverage_gate(task, model, dry_run, max_usd=ccap)
            except Exception:
                with lock:
                    spend["usd"] -= est
                raise
            with lock:
                spend["usd"] += ccost - est  # reconcile reservation against real cost
                record_actual_cost(spend, ccost, "coverage")
            if gap:
                log(f"{tid}: critic coverage gate flagged a gap — {coverage_note}")
        else:
            log(f"{tid}: critic coverage gate SKIPPED — budget governor")

        # Verify stage — spawn the configured verifiers, then GATE IN CODE.
        verify = task.get("verify", "single")
        verdicts = []
        for i, (persona, verdict_kind) in enumerate(VERIFY_PLANS.get(verify, [])):
            with lock:
                est = reserved_estimate(spend, plan, "verify")
                if spend["usd"] + est > budget:
                    log(f"{tid}: verify {persona} SKIPPED — budget governor")
                    verdicts.append((verdict_kind, "INCONCLUSIVE", None))
                    continue
                spend["usd"] += est   # reserve atomically with the check — see note above
            suffix = "verdict.md" if verdict_kind == "confirm" else "refute.md"
            label = f"{tid}.v{i}"
            vprompt = (f"Verify this claim from wire/{tid}.result.md. "
                       f"{'Try to CONFIRM by independent execution' if verdict_kind=='confirm' else 'Try to REFUTE it (a different failure mode)'}. "
                       f"Tag your verdict executed/static. If you ran any command as evidence "
                       f"(grep, git show, running a test), quote it in a fenced "
                       f"```code block``` or on a line starting with `$ ` — the driver's "
                       f"evidence gate strongly prefers those two forms; a command mentioned only "
                       f"in prose risks being treated as no evidence at all, discarding your "
                       f"verdict as INCONCLUSIVE even if you did the work.")
            if dry_run:
                dv = task.get("dry_verdict", "HOLDS")   # stub includes command evidence so it clears the gate
                if verdict_kind == "confirm":
                    obs = "observed: matches" if dv == "HOLDS" else "observed: mismatch"
                    body = f"{dv}(executed)\n```\n$ ran the check\n{obs}\n```\n"
                else:
                    body = ("SURVIVES\n```\n$ attempted the attack\nno break\n```\n"
                            if dv == "HOLDS" else
                            "REFUTED\n```\n$ attempted the attack\nbroke it\n```\n")
                dry = {"body": body, "cost": 0.03}
            else:
                dry = None
            with lock:
                vcap = max(budget - spend["usd"], est)
            # Verify runs in the SAME cwd as the task it's checking (worktree or REPO_ROOT) —
            # a verifier told to "confirm by independent execution" against a target repo can't
            # do that if it's sandboxed to the achtopus repo while the task it's verifying was
            # isolated elsewhere. Seen live: an isolated task produced a good result, but its
            # tuner verdict came back INCONCLUSIVE because it had no filesystem access to the
            # repo it was asked to independently re-derive facts from.
            try:
                vcost, vok = run_agent(persona, vprompt, label, suffix, model, cwd, dry, max_usd=vcap)
            except Exception:
                with lock:
                    spend["usd"] -= est
                raise
            with lock:
                spend["usd"] += vcost - est   # reconcile reservation against real cost
                record_actual_cost(spend, vcost, "verify")
            text = ""
            vpath = os.path.join(WIRE_DIR, f"{label}.{suffix}")
            if os.path.exists(vpath):
                text = open(vpath, encoding="utf-8").read()
            cv = classify(text, verdict_kind)
            if cv[0] == "INCONCLUSIVE" and re.search(r"\b(HOLDS|SURVIVES)\b", (text or "").upper()):
                log(f"{label}: evidence gate vetoed a claimed pass (no logged command / placeholder) → INCONCLUSIVE")
            verdicts.append((verdict_kind, *cv))

        accepted, reason = decide([(k, v, t) for k, v, t in verdicts])
        wire_state(tid, task["persona"], "accepted" if accepted else "rejected")
        if coverage_note:
            reason = f"{reason}; {coverage_note}"
        return {"id": tid, "outcome": "accepted" if accepted else "rejected",
                "reason": reason, "cost": cost, "coverage_gap": bool(coverage_note)}
    finally:
        if wt:
            remove_worktree(plan["target_repo"], wt)
            task["_wt"] = None


# ---- plan validation: a malformed plan fails loudly, never mid-run ------------

def infer_deps(task, all_ids):
    """Auto-detect same-run task ids a task's prompt tells it to read (e.g. "read wire/t2.result.md",
    or a "t1..t5" range shorthand). A safety net for plans that reference other tasks' output
    without declaring "depends_on" explicitly — without this, concurrent dispatch can spawn a
    task before the results it's told to read even exist yet (seen live: a coverage/synthesis
    task raced ahead of the domain reviews it depended on and reported them as "never posted"
    when they'd simply not finished yet).

    Requires a "wire/" prefix before the id, not just a bare word match — a conductor-authored
    plan can give tasks human-readable ids like "correctness" or "security" that also occur as
    ordinary English words in an unrelated task's prompt (e.g. "touches security-sensitive
    surfaces"), and a bare-word match created a false wire/t2.result.md-style dependency loop
    live (brief <-> correctness/observability/security), hanging every task as "unresolved
    circular dependency" for the whole run."""
    prompt = task.get("prompt", "")
    tid = task["id"]
    found = set()
    for other in all_ids:
        if other != tid and re.search(rf"wire/{re.escape(other)}\.result\.md\b", prompt):
            found.add(other)
    for m in re.finditer(r"\bt(\d+)\s*(?:\.\.|-)\s*t(\d+)\b", prompt):
        lo, hi = int(m.group(1)), int(m.group(2))
        for n in range(lo, hi + 1):
            cand = f"t{n}"
            if cand in all_ids and cand != tid:
                found.add(cand)
    return found


def validate_plan(plan):
    if not isinstance(plan, dict) or not isinstance(plan.get("tasks"), list) or not plan["tasks"]:
        raise ValueError("plan must be an object with a non-empty 'tasks' array")
    seen = set()
    for i, t in enumerate(plan["tasks"]):
        where = f"tasks[{i}]"
        tid = t.get("id")
        if not isinstance(tid, str) or not re.fullmatch(r"[A-Za-z0-9_-]+", tid or ""):
            raise ValueError(f"{where}: 'id' must match [A-Za-z0-9_-]+ (got {tid!r})")
        if tid in seen:
            raise ValueError(f"{where}: duplicate id {tid!r}")
        seen.add(tid)
        if t.get("persona") not in VALID_PERSONAS:
            raise ValueError(f"{where}: 'persona' must be one of {sorted(VALID_PERSONAS)}")
        if not isinstance(t.get("prompt"), str) or not t["prompt"].strip():
            raise ValueError(f"{where}: 'prompt' must be a non-empty string")
        if t.get("verify", "single") not in VERIFY_PLANS:
            raise ValueError(f"{where}: 'verify' must be one of {sorted(VERIFY_PLANS)}")
        if "scope" in t and not (isinstance(t["scope"], list)
                                  and all(isinstance(s, str) for s in t["scope"])):
            raise ValueError(f"{where}: 'scope', if present, must be a list of strings")
        if "target" in t and not isinstance(t["target"], str):
            raise ValueError(f"{where}: 'target', if present, must be a string")
        if "depends_on" in t and not (isinstance(t["depends_on"], list)
                                        and all(isinstance(d, str) for d in t["depends_on"])):
            raise ValueError(f"{where}: 'depends_on', if present, must be a list of strings")
    for i, t in enumerate(plan["tasks"]):
        for dep in t.get("depends_on", []):
            if dep not in seen:
                raise ValueError(f"tasks[{i}]: depends_on references unknown id {dep!r}")
            if dep == t["id"]:
                raise ValueError(f"tasks[{i}]: depends_on cannot reference its own id")
    return plan


# ---- --goal mode: the ONE LLM coordination call authors the plan ---------------

PLAN_CONTRACT = """

## Deterministic-driver mode (you are authoring a plan, not running it)
Emit a machine-readable plan to the ABSOLUTE path `{plan_path}` and NOTHING to the manifest.
Write ONE JSON object, no prose around it, matching exactly:
  {{"budget_usd": <float>, "est_agent_usd": <float>, "default_model": "<model-id>",
    "target_repo": "<abs path or omit>",
    "base_ref": "<e.g. origin/main — optional; lets the driver precompute the diff for free>",
    "tasks": [{{"id":"t1","persona":"soloist","prompt":"<self-contained task>",
               "verify":"none|single|pair|quorum3|quorum5","model":"<optional override>",
               "isolate": true,
               "scope": ["<optional list of allowed path prefixes/globs, relative to target_repo>"],
               "target": "<optional path this task intends to touch>",
               "depends_on": ["<optional list of task ids that must finish first>"]}}]}}
Rules you must honor while authoring:
- If a task's prompt tells it to read another task's wire/<id>.result.md output, you MUST list
  that id in `depends_on` — the driver dispatches concurrently by default and will NOT wait for
  another task to finish unless told to. A task that reads output that doesn't exist yet will
  wrongly report it as missing, not merely late.
- **Your own budget cap for THIS call is intentionally small and has NOTHING to do with the
  plan's execution budget.** You may see a low `--max-budget-usd` on this very invocation —
  that limits only the cost of writing the plan, not what the plan is allowed to spend. Never
  read a tight cap on yourself as a reason to skip planning and do the review inline instead;
  that defeats the entire point of this mode. No matter how constrained THIS call feels,
  you MUST emit a valid plan.json and nothing else — do not write a report, scorecard, or
  findings directly. If you are unsure the goal is affordable, express that by setting a
  small/cheap plan (fewer tasks, cheaper `model`), never by abandoning the plan format.
- `scope`/`target` are optional and only meaningful for luthier/prober-style tasks that
  execute real commands with a blast radius. If you set one, set the other — the driver's
  scope governor only enforces the allowlist when both are present on the same task.
- Do your step 1a surface inventory FIRST: list the surfaces the goal spans and give each an
  owning task. A surface with no task is how real defects slip — cover it or omit it deliberately.
- Right-size verify: default `single`; use `pair`/`quorum3` ONLY on the 2-3 riskiest claims.
  Don't add voters to low-stakes or already-clean checks.
- Set `base_ref` when you know the upstream branch (e.g. `origin/main`) — the driver then
  precomputes `wire/cache/diff.patch` itself, in plain code, for $0.00, BEFORE any agent runs.
  Every task's prompt should still say to check `wire/cache/diff.patch` (or run
  `bin/cache get diff.patch`) FIRST and only fall back to its own `git diff`/`gh pr view` if
  that's missing — don't rely on a `composer` task alone to produce it; the driver may have
  already done it for free. For any OTHER repeated fetch a task expects a peer to also need
  (a large `gh api` call, a slow build/lint run), tell it to use
  `bin/cache fetch <key> -- <command...>` instead of running the command bare — that's the
  general get-or-fetch-and-store primitive (see bin/_cache_lib.py), not just for diffs.
- Set `budget_usd` from your step 1b projection (agents x turns x context), not agent count.
- personas available: {personas}. Ids must be unique and match [A-Za-z0-9_-]+.
Return only after the file is written and is valid JSON. Writing prose instead of the file,
for any reason including cost, is a contract violation — the driver will abort the whole run.
"""


CONDUCTOR_CAP_USD = 1.00   # the plan-authoring call is supposed to be cheap — see docs/harness.md;
                           # this is a hard backstop, not a soft estimate, after one call burned
                           # $5.31 with no output because nothing capped it.


def author_plan(goal, plan_path, model, budget, target_repo=None):
    log("conductor authoring plan.json (the single coordination LLM call)")
    contract = PLAN_CONTRACT.format(plan_path=plan_path, personas=sorted(VALID_PERSONAS))
    system = persona_body("conductor") + contract
    cap = min(budget, CONDUCTOR_CAP_USD) if budget is not None else CONDUCTOR_CAP_USD
    # The raw goal reads as a complete task ("review it for launch readiness") and a model will
    # happily just DO it, overriding the system prompt's plan-authoring mode — seen live: the
    # conductor wrote a full PRR verdict as prose instead of a plan.json, twice, despite the
    # system prompt saying not to. Frame the user turn itself as a planning request, not the task.
    prompt = (f"Do not perform this task yourself. Author a plan.json for OTHER agents to "
              f"perform it, per the Deterministic-driver mode section of your system prompt. "
              f"The task to plan for: {goal}")
    if target_repo:
        # Without this, the conductor has no way to know a local checkout exists at all — it was
        # seen authoring tasks that told agents to fetch the diff over the network (gh/clone),
        # which fails in sandboxes with no egress, when a local git checkout was sitting right
        # there the whole time. Every task that needs to read/run against the repo MUST set
        # "isolate": true (and "target_repo" matching this path) so the driver worktree-isolates
        # it with cwd + --add-dir pointed at the real checkout instead of the achtopus repo.
        prompt += (
            f"\n\nA local git checkout of the target repo is already available at "
            f"`{target_repo}` — you MUST set `\"target_repo\": \"{target_repo}\"` at the top "
            f"level of the plan, and set `\"isolate\": true` on every task that needs to read "
            f"the diff, run commands, or inspect files in that repo. Do NOT write tasks that "
            f"rely on network access (gh CLI, git clone, curl) to reach the repo or its PR — "
            f"assume no network egress and ground everything through the local isolated "
            f"checkout instead."
        )
    cmd = ["claude", "-p", prompt, "--append-system-prompt", system,
           "--output-format", "json", "--model", model,
           "--permission-mode", "acceptEdits", "--add-dir", WIRE_DIR,
           "--max-budget-usd", f"{cap:.2f}"]
    proc = subprocess.run(cmd, cwd=REPO_ROOT, capture_output=True, text=True)
    parsed = None
    try:
        parsed = json.loads(proc.stdout)
        cost = float(parsed.get("total_cost_usd", 0.0))
        log(f"conductor done (${cost:.3f})")
    except Exception:
        _log_failure("conductor", proc)
    if not os.path.exists(plan_path):
        # The call can "succeed" (parseable JSON, real cost) yet still not write the file —
        # e.g. it hit the budget cap mid-task, or replied with prose instead of writing.
        # _log_failure only fires on a parse exception, so log the conductor's own reply here.
        if parsed is not None:
            reply = str(parsed.get("result", parsed))[:800]
            log(f"conductor reply (truncated): {reply}")
        sys.exit(f"conductor did not write a plan.json (capped at ${cap:.2f}) — aborting")
    plan = validate_plan(json.load(open(plan_path, encoding="utf-8")))
    if budget is not None:
        plan["budget_usd"] = budget      # CLI override wins over the conductor's estimate
    return plan


def main():
    ap = argparse.ArgumentParser()
    ap.add_argument("plan", nargs="?", help="path to a plan.json (or use --goal)")
    ap.add_argument("--goal", help="have the conductor author the plan from this goal")
    ap.add_argument("--budget", type=float, help="override budget_usd")
    ap.add_argument("--model", help="override default_model — the tier every task-execution "
                    f"persona runs on unless a task sets its own 'model' (default: {DEFAULT_MODEL})")
    ap.add_argument("--premium-model", help="model tier for the conductor's plan-authoring call "
                    f"and the scribe's final synthesis (default: {DEFAULT_MODEL})")
    ap.add_argument("--dry-run", action="store_true", help="stub agents; test orchestration free")
    ap.add_argument("--concurrency", type=int, default=6)
    ap.add_argument("--target-repo", help="the ONLY target_repo a plan's worktree-isolate tasks "
                     "may use; a plan's own declared target_repo is untrusted (a hand-authored or "
                     "--goal/conductor-authored plan.json could otherwise point worktree isolation "
                     "at an arbitrary path) and is ignored unless it matches this exactly")
    ap.add_argument("--fresh", action="store_true", help="opt out of the default idempotent "
                     "rerun behavior: clears wire/ and re-authors the plan (with --goal) instead "
                     "of reusing wire/.run_state.json and the last-authored wire/plan.json. Use "
                     "this for a genuinely new run rather than continuing/retrying a prior one.")
    args = ap.parse_args()

    if bool(args.plan) == bool(args.goal):
        ap.error("provide exactly one of <plan.json> or --goal")
    acquire_run_lock()
    try:
        _main_body(args)
    finally:
        release_run_lock()


def _main_body(args):
    premium_model = args.premium_model or DEFAULT_MODEL
    if args.goal:
        plan_path = os.path.join(WIRE_DIR, "plan.json")
        goal_path = os.path.join(WIRE_DIR, ".last_goal.txt")
        os.makedirs(WIRE_DIR, exist_ok=True)
        try:
            last_goal = open(goal_path, encoding="utf-8").read()
        except FileNotFoundError:
            last_goal = None
        goal_changed = last_goal is not None and last_goal != args.goal
        if goal_changed and not args.fresh:
            log("idempotent: --goal text differs from the last run's goal — re-authoring "
                "the plan instead of silently reusing the stale one")
        if not args.fresh and not goal_changed and os.path.exists(plan_path):
            # Reuse the plan a prior --goal run already authored, rather than re-invoking the
            # conductor — a fresh conductor call isn't guaranteed to assign the same task ids to
            # the same work, which would silently break matching against wire/.run_state.json.
            log(f"idempotent: reusing previously-authored {plan_path} instead of re-authoring")
            plan = validate_plan(json.load(open(plan_path, encoding="utf-8")))
            if args.budget is not None:
                plan["budget_usd"] = args.budget
        else:
            plan = author_plan(args.goal, plan_path, premium_model, args.budget, args.target_repo)
            open(goal_path, "w", encoding="utf-8").write(args.goal)
    else:
        plan = validate_plan(json.load(open(args.plan, encoding="utf-8")))
        if args.budget is not None:
            plan["budget_usd"] = args.budget
    if args.model is not None:
        plan["default_model"] = args.model      # CLI tier flag wins over the plan's own default
    if plan.get("target_repo"):
        # A plan's own target_repo is untrusted — hand-authored or conductor/--goal-authored
        # plan.json could otherwise point worktree isolation's `git -C <target_repo> worktree add`
        # at an arbitrary path with no containment check. Only the human-supplied --target-repo
        # CLI flag is trusted; drop the plan's value (disabling isolation) if it doesn't match.
        if not args.target_repo or os.path.abspath(plan["target_repo"]) != os.path.abspath(args.target_repo):
            log(f"target_repo {plan['target_repo']!r} in the plan does not match "
                f"--target-repo{' (not supplied)' if not args.target_repo else ''} — "
                f"ignoring it; worktree isolation is disabled for this run")
            plan["target_repo"] = None
    elif args.target_repo:
        # The plan omitted target_repo entirely — e.g. a --goal/conductor-authored plan that
        # didn't wire it in. The CLI flag is still the trusted source of truth: use it directly
        # rather than silently running with no repo access at all (root cause of a real run
        # where every task fell back to network calls that don't exist in this sandbox, cascading
        # into rejected verdicts across the board instead of failing fast).
        plan["target_repo"] = args.target_repo

    isolating_tasks = any(t.get("isolate") for t in plan["tasks"])
    if args.target_repo and not isolating_tasks:
        # A target_repo was supplied but not one task actually asked to be isolated into it —
        # every task's cwd would stay at the achtopus repo with no visibility into the real
        # checkout, and would predictably fail to ground itself. Bail now instead of spending
        # the budget on tasks that can't do their job — this is the failure mode from a live
        # run where the conductor's plan never used --target-repo at all.
        sys.exit(f"--target-repo {args.target_repo!r} was supplied but no task in the plan sets "
                 f"\"isolate\": true — every task would run with no access to that repo and no "
                 f"network fallback. Aborting before spending budget on a run that can't ground "
                 f"itself; re-author the plan so at least one task isolates into the target repo.")
    if isolating_tasks and not plan.get("target_repo"):
        # The mismatched-target_repo branch above can drop plan["target_repo"] to None while
        # tasks still declare isolate: true — the bail check above wouldn't catch this (a task
        # DOES isolate), but make_worktree() never runs without a plan-level target_repo (it's
        # guarded on plan.get("target_repo") in process_task), so those tasks would silently run
        # at the achtopus repo with no isolation anyway. Same failure mode, different door — bail
        # here too rather than let it happen quietly.
        sys.exit(f"plan declares isolate: true tasks but has no usable target_repo (either none "
                 f"was set, or it didn't match --target-repo{'' if args.target_repo else ' — none was supplied on the CLI either'}). "
                 f"Aborting before spending budget on tasks that would run with no repo access.")
    budget = float(plan.get("budget_usd", 1e9))
    spend = {"usd": 0.0, "n": 0, "sum_usd": 0.0}
    tasks = plan["tasks"]

    # Idempotent reruns keep wire/ (a fresh `clear` would archive away the very artifacts a
    # reused "accepted" task's downstream readers/synthesis need) and skip real dispatch for any
    # task already recorded accepted/rejected — those already spent real budget on a real verdict.
    # budget-skipped/dep-skipped/scope-blocked tasks are NOT reused (nothing actually ran) and
    # dispatch normally — this is exactly what lets "rerun at a higher --budget" finish the tasks
    # a too-small prior run's governor cut off, without re-paying for work already accepted.
    prior_state = {} if (args.fresh or args.dry_run) else load_run_state()
    task_by_id = {t["id"]: t for t in tasks}
    already_resolved = {tid: r for tid, r in prior_state.items()
                         if r.get("outcome") in ("accepted", "rejected")
                         and tid in task_by_id
                         and r.get("fingerprint") == task_fingerprint(task_by_id[tid])}
    stale = {tid for tid, r in prior_state.items()
             if r.get("outcome") in ("accepted", "rejected") and tid in task_by_id
             and r.get("fingerprint") != task_fingerprint(task_by_id[tid])}
    if stale:
        log(f"idempotent: {len(stale)} previously-resolved task(s) changed content since their "
            f"last verdict ({', '.join(sorted(stale))}) — re-running instead of reusing stale state")
    tasks_to_run = [t for t in tasks if t["id"] not in already_resolved]
    if already_resolved:
        log(f"idempotent: reusing {len(already_resolved)} already-resolved task(s) "
            f"({', '.join(sorted(already_resolved))}); {len(tasks_to_run)} will run")

    # `clear` (not `init`) so each run starts from a fresh manifest: bin/run has no
    # resume-from-manifest logic — every task in the plan dispatches fresh every time — so an
    # `init`-only manifest would silently accumulate/collide with a prior run's same-named task
    # ids (t1.result.md etc. overwritten in place). `clear` archives the prior run's full file
    # set into wire/_archive/<timestamp>/ first, namespacing each run by its own archive folder.
    # Idempotent mode (the default) skips this: reused tasks' wire/<id>.result.md artifacts
    # must survive. --fresh opts back into always clearing for a genuinely new run. --dry-run
    # always clears too — it never writes wire/.run_state.json (a dry run isn't real reusable
    # work), so without a clear here the manifest would still accumulate claims across repeated
    # dry runs with nothing to reuse for it, just noisy "already accepted" reclaim warnings.
    if args.fresh or args.dry_run:
        subprocess.run([WIRE, "clear"], cwd=REPO_ROOT, check=False, capture_output=True)
    log(f"{len(tasks)} tasks, budget ${budget:.2f}, "
        f"{'DRY-RUN' if args.dry_run else 'LIVE'}, concurrency {args.concurrency}")

    # Zero-LLM-cost precompute BEFORE roll call — if this lands the diff/PR cache, every
    # task's roll call and real call gets context_brief_note() pointed at it from turn one,
    # instead of the composer needing an extra turn to fetch what plain code already fetched.
    precompute_context_cache(plan, args.dry_run)

    # Roll call only the tasks that will actually (re)run — an already-resolved task doesn't
    # need re-confirming, and preflighting it would waste real money on a no-op check.
    spend["usd"] += preflight_roll_call(tasks_to_run, plan, args.dry_run, args.concurrency)

    import threading
    lock = threading.Lock()
    results = [{"id": tid, "outcome": r["outcome"], "reason": r.get("reason"), "cost": 0.0}
               for tid, r in already_resolved.items()]
    all_ids = {t["id"] for t in tasks}
    deps = {t["id"]: set(t.get("depends_on", [])) | infer_deps(t, all_ids) for t in tasks}

    # A cycle in the FINAL graph (explicit depends_on plus infer_deps) would otherwise just
    # drain to "unresolved/circular dependency" once the dispatch loop empties — indistinguishable
    # from a budget/timing skip, giving no signal that the plan itself is structurally broken.
    # Fail loudly here instead, before any real work (or roll-call spend) is wasted chasing it.
    unresolved = set(deps) - set(already_resolved)
    resolved = set(already_resolved)
    while True:
        ready = {tid for tid in unresolved if deps[tid] <= resolved}
        if not ready:
            break
        resolved |= ready
        unresolved -= ready
    if unresolved:
        for t in tasks:
            if t.get("_wt"):
                remove_worktree(plan["target_repo"], t["_wt"])
        sys.exit(f"plan has a circular dependency among {sorted(unresolved)} — "
                 f"aborting before any real dispatch (${spend['usd']:.3f} already spent on roll call)")

    for tid, d in deps.items():
        if d:
            log(f"{tid}: depends on {sorted(d)} — dispatch held until they finish")
    pending = {t["id"]: t for t in tasks_to_run}
    done_ids = set(already_resolved)
    with cf.ThreadPoolExecutor(max_workers=args.concurrency) as ex:
        in_flight = {}

        def submit_ready():
            for tid in list(pending):
                if deps[tid] <= done_ids:
                    t = pending.pop(tid)
                    fut = ex.submit(process_task, t, plan, spend, budget, args.dry_run, lock)
                    in_flight[fut] = t

        submit_ready()
        while in_flight:
            done, _ = cf.wait(in_flight.keys(), return_when=cf.FIRST_COMPLETED)
            for fut in done:
                t = in_flight.pop(fut)
                r = fut.result()
                results.append(r)
                done_ids.add(t["id"])
                tag = {"accepted": "\033[32m✓\033[0m", "rejected": "\033[31m✗\033[0m"}.get(
                    r["outcome"], "\033[33m•\033[0m")
                log(f"{tag} {r['id']}: {r['outcome']}"
                    + (f" — {r.get('reason')}" if r.get("reason") else "")
                    + f"  (${r['cost']:.3f})")
            submit_ready()
        for tid, t in pending.items():
            log(f"{tid}: SKIPPED — unresolved/circular dependency on {sorted(deps[tid] - done_ids)}")
            results.append({"id": tid, "outcome": "dep-skipped", "cost": 0.0})

    # Sweep any worktree preflight created that process_task never reached to clean up itself
    # (dep-skipped, budget-skipped, scope-blocked all return before its own cleanup runs).
    if plan.get("target_repo"):
        for t in tasks:
            if t.get("_wt"):
                remove_worktree(plan["target_repo"], t["_wt"])
                t["_wt"] = None

    # Persist outcomes for the next idempotent rerun. Only accepted/rejected are ever reused
    # (see already_resolved above) — recording the rest too is harmless and keeps the file a
    # complete picture of the last attempt at each task.
    if not args.dry_run:
        for r in results:
            entry = {"outcome": r["outcome"], "reason": r.get("reason")}
            if r["id"] in task_by_id:
                entry["fingerprint"] = task_fingerprint(task_by_id[r["id"]])
            prior_state[r["id"]] = entry
        save_run_state(prior_state)

    # Synthesis: the ONE genuinely-LLM coordination step, run once on accepted work.
    accepted = [r for r in results if r["outcome"] == "accepted"]
    log(f"synthesis: {len(accepted)} accepted result(s) → scribe (skipped in dry-run)"
        if args.dry_run else "handing accepted results to scribe")
    if not args.dry_run and accepted:
        ids = ",".join(r["id"] for r in accepted)
        scribe_cap = max(budget - spend["usd"], 0.50)
        run_agent("scribe", f"Synthesize the accepted results ({ids}) into a final report "
                  f"using docs/report-template.md. Read only accepted wire/<id>.result.md files.",
                  "final", "report.md", premium_model, REPO_ROOT,
                  max_usd=scribe_cap)

    n_acc = sum(1 for r in results if r["outcome"] == "accepted")
    n_rej = sum(1 for r in results if r["outcome"] == "rejected")
    n_skip = sum(1 for r in results if r["outcome"] not in ("accepted", "rejected"))
    n_budget_skip = sum(1 for r in results if r["outcome"] == "budget-skipped")
    print(f"\n\033[1mAchtopus run complete\033[0m")
    print(f"  accepted {n_acc}  rejected {n_rej}  skipped/blocked {n_skip}")
    print(f"  spend ${spend['usd']:.2f} / budget ${budget:.2f}"
          + ("  \033[31m(governor engaged)\033[0m" if n_budget_skip else ""))
    print(f"  coordination cost: $0.00 — no LLM in the loop (see docs/harness.md)")

    scorecard = tally_scorecard(results)
    if scorecard is not None:
        c = scorecard["counts"]
        print(f"  domain tally ({scorecard['n_domains']}): "
              f"\033[32m✅ {c['green']}\033[0m  \033[33m⚠️ {c['warning']}\033[0m  "
              f"\033[31m🔴 {c['red']}\033[0m  →  \033[1m{scorecard['verdict']}\033[0m")


if __name__ == "__main__":
    main()
