#!/usr/bin/env bash
# Achtopus — file-based coordination wire.
# A greppable, human-readable coordination channel for the octopus's eight arms.
# No daemon, no database: the filesystem IS the wire. Every agent reads/writes the
# same files under $WIRE, so the state of the world is always `cat`-able and `grep`-able.
#
# Usage:
#   wire init                       # ensure a manifest exists (does NOT clear; use `clear` to reset)
#   wire post    <id> <role> <text> # append a free-text note to the manifest for task <id>
#   wire claim   <id> <role>        # take ownership of task <id> (guarded, atomic)
#   wire status  <id> <state>       # set task <id> to done|accepted|rejected|blocked
#   wire unblock <id>               # move a blocked/rejected task back to open for re-claim
#   wire manifest                   # print the ledger
#   wire state   <id>               # print the current (latest) state of one task
#   wire results                    # list all posted result artifacts
#   wire stale   [minutes]          # list tasks stuck in `claimed` longer than N min (default 30)
#   wire watch   [pattern]          # tail the manifest for actionable state changes
#   wire clear                      # archive the current wire into wire/_archive/<stamp>
#
# States: claimed -> done -> (accepted | rejected). blocked is a stuck task needing help.
# rejected/blocked are re-claimable (reassign); claimed/done/accepted are held (active).
#
# Current state = the LAST state line for a task id (last-line-wins over the append log).
# A "state line" has the shape: [<utc>] <id> <role> <state>  (post notes use `note` and
# are ignored by state logic). Matching is field-exact on <id>, so t1 never matches t10.

set -euo pipefail

ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
WIRE="${ACHT_WIRE:-$ROOT/wire}"
MANIFEST="$WIRE/manifest.md"
LOCK="$WIRE/.lock"

mkdir -p "$WIRE"

stamp() { date -u +"%Y-%m-%dT%H:%M:%SZ"; }

# Task ids must be a simple token. Rejecting anything else prevents a backslash (which
# `awk -v` would C-escape, breaking the lookup) or whitespace from corrupting manifest lines.
require_id() {
  case "$1" in
    ""|*[!A-Za-z0-9_-]*) echo "bad task id: '$1' (allowed: letters, digits, - _)"; exit 2 ;;
  esac
}

# Collapse CR/LF in free text so a `post` note can never inject a second physical manifest
# line that would be misread as a state line.
sanitize() { printf '%s' "$1" | tr '\r\n' '  '; }

# Atomic advisory lock via mkdir (portable; macOS ships no flock). Held for the
# read-modify-write in claim so two concurrent claimers can't both pass the guard. Records
# the holder's PID so a lock left behind by a hard-killed process (e.g. a driver run that
# got SIGKILLed mid-claim) is detected as stale and cleared rather than wedging every future
# claim for good — seen live: a killed background run left $LOCK on disk and every
# concurrent claim in the next run blocked the full timeout before failing.
lock() {
  local n=0
  until mkdir "$LOCK" 2>/dev/null; do
    local holder; holder="$(cat "$LOCK/pid" 2>/dev/null || true)"
    if [ -n "$holder" ] && ! kill -0 "$holder" 2>/dev/null; then
      rm -rf "$LOCK"; continue   # holder process is gone — stale lock, clear and retry now
    fi
    sleep 0.05; n=$((n+1))
    [ "$n" -gt 200 ] && { echo "wire: lock timeout"; exit 4; }
  done
  echo $$ > "$LOCK/pid"
}
unlock() { rm -rf "$LOCK" 2>/dev/null || true; }

ensure_manifest() {
  if [ ! -f "$MANIFEST" ]; then
    {
      echo "# Achtopus — Wire Manifest"
      echo ""
      echo "One fact per line. Format: [<utc>] <id> <role> <state> — <note>"
      echo ""
    } > "$MANIFEST"
  fi
}

# Latest state token for an id (empty if never seen). Ignores free-text `note` lines.
latest_state() {
  local id="$1"
  awk -v id="$id" '
    $2==id && ($4=="claimed"||$4=="done"||$4=="accepted"||$4=="rejected"||$4=="blocked"||$4=="open") { last=$4 }
    END { print last }
  ' "$MANIFEST"
}

# Current owner for an id (role of its latest claim). Empty if unclaimed.
latest_owner() {
  local id="$1"
  awk -v id="$id" '$2==id && $4=="claimed" { owner=$3 } END { print owner }' "$MANIFEST"
}

cmd="${1:-manifest}"; shift || true

case "$cmd" in
  init)
    ensure_manifest
    echo "[$(stamp)] — wire init (manifest ready at $MANIFEST)"
    ;;

  post)
    id="${1:?task id required}"; role="${2:?role required}"; shift 2
    require_id "$id"
    text="$(sanitize "$*")"
    ensure_manifest
    echo "[$(stamp)] $id $role note — $text" >> "$MANIFEST"
    echo "posted: $id ($role)"
    ;;

  claim)
    id="${1:?task id required}"; role="${2:?role required}"
    require_id "$id"
    ensure_manifest
    lock; trap unlock EXIT
    state="$(latest_state "$id")"
    case "$state" in
      claimed|done|accepted)
        echo "WARN: $id is $state (owner: $(latest_owner "$id")) — resume that owner, don't double-play:"
        awk -v id="$id" '$2==id' "$MANIFEST" | tail -1
        unlock; trap - EXIT
        exit 3
        ;;
    esac
    # empty | open | rejected | blocked -> claimable (fresh claim or reassignment)
    echo "[$(stamp)] $id $role claimed — owner set${state:+ (reassigned from $state)}" >> "$MANIFEST"
    unlock; trap - EXIT
    echo "claimed: $id by $role${state:+ (was $state)}"
    ;;

  status)
    id="${1:?task id required}"; state="${2:?state required}"
    require_id "$id"
    case "$state" in done|accepted|rejected|blocked) ;; *)
      echo "bad state: $state (want done|accepted|rejected|blocked; use claim to set claimed)"; exit 2 ;;
    esac
    ensure_manifest
    owner="$(latest_owner "$id")"; owner="${owner:--}"
    echo "[$(stamp)] $id $owner $state — status set" >> "$MANIFEST"
    echo "status: $id → $state"
    ;;

  unblock)
    id="${1:?task id required}"
    require_id "$id"
    ensure_manifest
    state="$(latest_state "$id")"
    case "$state" in
      blocked|rejected)
        echo "[$(stamp)] $id - open — unblocked (was $state)" >> "$MANIFEST"
        echo "unblocked: $id (was $state) — now open for re-claim" ;;
      "") echo "unblock: $id has no state yet; it's already open"; exit 0 ;;
      *)  echo "unblock: $id is $state, not blocked/rejected — nothing to do"; exit 2 ;;
    esac
    ;;

  manifest)
    ensure_manifest
    cat "$MANIFEST"
    ;;

  state)
    id="${1:?task id required}"; require_id "$id"; ensure_manifest
    s="$(latest_state "$id")"; echo "${s:-open}"
    ;;

  results)
    shopt -s nullglob
    files=( "$WIRE"/*.result.md "$WIRE"/*.review.md "$WIRE"/*.verdict.md "$WIRE"/*.refute.md )
    if [ ${#files[@]} -eq 0 ]; then echo "(no result artifacts yet)"; else printf '%s\n' "${files[@]}"; fi
    ;;

  stale)
    ensure_manifest
    mins="${1:-30}"
    now=$(date -u +%s)
    # Report tasks whose latest state is `claimed` and whose claim is older than $mins.
    awk '$4=="claimed"||$4=="done"||$4=="accepted"||$4=="rejected"||$4=="blocked"||$4=="open" {
           ts=$1; gsub(/[\[\]]/,"",ts); state[$2]=$4; when[$2]=ts }
         END { for (id in state) if (state[id]=="claimed") print id, when[id] }' "$MANIFEST" |
    while read -r id ts; do
      # portable ISO8601 -> epoch (macOS date -j; fall back to GNU date -d)
      e=$(date -j -u -f "%Y-%m-%dT%H:%M:%SZ" "$ts" +%s 2>/dev/null || date -u -d "$ts" +%s 2>/dev/null || echo "")
      [ -z "$e" ] && { echo "$id  claimed  (age: ?, ts=$ts)"; continue; }
      age=$(( (now - e) / 60 ))
      [ "$age" -ge "$mins" ] && echo "$id  claimed  age=${age}m  since=$ts  ← stale, consider unblock/reassign"
    done
    ;;

  watch)
    ensure_manifest
    pattern="${1:-claimed|done|accepted|rejected|blocked|conflict}"
    echo "watching $MANIFEST for: $pattern  (ctrl-c to stop)"
    tail -n 0 -f "$MANIFEST" | grep -E --line-buffered "$pattern"
    ;;

  clear)
    ensure_manifest
    dest="$WIRE/_archive/$(stamp)"
    mkdir -p "$dest"
    shopt -s nullglob
    for f in "$WIRE"/*.md; do
      [ "$(basename "$f")" = "manifest.md" ] && cp "$f" "$dest/" || mv "$f" "$dest/"
    done
    rm -f "$MANIFEST"
    ensure_manifest
    echo "archived prior wire into $dest; fresh manifest ready"
    ;;

  *)
    grep -E '^#( |$)' "$0" | sed 's/^# \{0,1\}//'
    exit 1
    ;;
esac
